/* app.wxss - 全局样式 */
page {
  --primary: #07C160;
  --primary-dark: #06AD56;
  --danger: #FA5151;
  --warning: #FFC300;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --bg: #f5f5f5;
  --bg-white: #ffffff;
  --border: #eeeeee;
  --shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg);
  box-sizing: border-box;
}

/* 通用按钮样式 */
.btn-primary {
  background-color: var(--primary);
  color: #fff;
  text-align: center;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  border: none;
}
.btn-primary:active { opacity: 0.85; }

.btn-outline {
  background-color: transparent;
  color: var(--primary);
  text-align: center;
  border-radius: 12rpx;
  padding: 18rpx 40rpx;
  font-size: 28rpx;
  border: 2rpx solid var(--primary);
}

.btn-danger {
  background-color: var(--danger);
  color: #fff;
  text-align: center;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  border: none;
}

.btn-disabled {
  background-color: #ccc;
  color: #fff;
  text-align: center;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  border: none;
}

/* 卡片 */
.card {
  background: var(--bg-white);
  border-radius: 16rpx;
  margin: 20rpx;
  padding: 24rpx;
  box-shadow: var(--shadow);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--border);
  margin: 20rpx 0;
}

/* flex */
.flex { display: flex; }
.flex-center { display: flex; align-items: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-col { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }

/* 价格 */
.price { color: var(--danger); font-weight: bold; }
.price-symbol { font-size: 24rpx; }
.price-value { font-size: 36rpx; }
.price-original { color: var(--text-light); text-decoration: line-through; font-size: 24rpx; margin-left: 10rpx; }

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
}
.tag-primary { background: rgba(7,193,96,0.1); color: var(--primary); }
.tag-hot { background: rgba(250,81,81,0.1); color: var(--danger); }

/* 安全区域 */
.safe-bottom { padding-bottom: env(safe-area-inset-bottom); }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--text-light);
}
.empty-state .icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-state .text { font-size: 28rpx; }
