/* pages/change-phone/change-phone.wxss - 复用通用表单样式 */
.cp-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-top: 20rpx;
}
.form-card {
  background-color: #ffffff;
  margin: 0 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}
.form-item {
  margin-bottom: 30rpx;
}
.form-item:last-child {
  margin-bottom: 0;
}
.form-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}
.form-input {
  height: 84rpx;
  background-color: #f5f5f5;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}
.ph { color: #cccccc; }
.submit-area {
  padding: 40rpx 20rpx;
}
.submit-btn {
  width: 100%;
  height: 88rpx;
  background-color: #07C160;
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 12rpx;
  border: none;
}
