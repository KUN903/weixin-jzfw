<!-- pages/order-list/order-list.wxml - 订单中心 -->
<view class="page-orders">
  <!-- 顶部标签切换 -->
  <scroll-view class="tab-bar" scroll-x>
    <view class="tab-item {{currentTab === index ? 'active' : ''}}"
          wx:for="{{tabs}}" wx:key="index" data-index="{{index}}" bindtap="switchTab">
      <text>{{item.label}}</text>
    </view>
  </scroll-view>

  <!-- 订单列表 -->
  <scroll-view scroll-y class="order-scroll" wx:if="{{!loading}}" refresher-enabled refresher-triggered="{{refreshing}}" bindrefresherrefresh="onPullDownRefresh">
    <view wx:if="{{orders.length === 0}}" class="empty-state">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无相关订单</text>
      <text class="empty-hint">去首页看看有什么需要的服务吧</text>
    </view>

    <view class="order-item" wx:for="{{orders}}" wx:key="order_no" data-orderno="{{item.order_no}}" bindtap="onTapOrder">
      <!-- 订单头部 -->
      <view class="order-header">
        <view class="order-header-left">
          <text class="order-no">订单号：{{item.order_no}}</text>
        </view>
        <text class="order-status status-{{item.status}}">
          {{item.status === 'pending' && item.pay_status === 0 ? '待支付' : item.status === 'pending' ? '待接单' : item.status === 'accepted' ? '已接单' : item.status === 'serving' ? '服务中' : item.status === 'completed' ? '待评价' : item.status === 'finished' ? '已完成' : item.status === 'cancelled' ? '已取消' : item.status === 'refunded' ? '已退款' : item.status}}
        </text>
      </view>

      <!-- 订单内容 -->
      <view class="order-body">
        <view class="order-cover">
          <text class="cover-text">{{item.svcCp2 || '家政'}}</text>
        </view>
        <view class="order-info">
          <text class="order-name">{{item.service_name || '家政服务'}}</text>
          <view class="order-meta">
            <text class="order-time" wx:if="{{item.service_date}}">📅 {{item.service_date}} {{item.service_time_slot || ''}}</text>
            <text class="order-worker" wx:if="{{item.worker_name}}">👨‍🔧 {{item.worker_name}}</text>
          </view>
          <view class="order-price-row">
            <text class="order-price">¥{{item.actual_price}}</text>
            <text class="order-discount" wx:if="{{item.discount > 0}}">已优惠¥{{item.discount}}</text>
          </view>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="order-actions">
        <!-- 待支付：取消 + 支付 -->
        <block wx:if="{{item.status === 'pending' && item.pay_status === 0}}">
          <text class="action-btn action-cancel" data-orderno="{{item.order_no}}" catchtap="onTapCancel">取消订单</text>
          <text class="action-btn action-pay" data-orderno="{{item.order_no}}" catchtap="onTapPay">去支付</text>
        </block>

        <!-- 待接单（已支付）：取消 -->
        <block wx:elif="{{item.status === 'pending'}}">
          <text class="action-btn action-cancel" data-orderno="{{item.order_no}}" catchtap="onTapCancel">取消订单</text>
        </block>

        <!-- 待评价 -->
        <block wx:elif="{{item.status === 'completed'}}">
          <text class="action-btn action-review" data-orderno="{{item.order_no}}" catchtap="onTapReview">去评价</text>
        </block>

        <!-- 其他状态：查看详情 -->
        <block wx:else>
          <text class="action-btn action-detail" data-orderno="{{item.order_no}}" catchtap="onTapOrder">查看详情</text>
        </block>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{loading}}" class="loading-hint">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>
</view>
