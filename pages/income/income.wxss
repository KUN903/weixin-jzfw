/* pages/income/income.wxss */
.income-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 收入总览 */
.income-summary {
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
}
.summary-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 30rpx;
}
.summary-main {
  display: flex;
  flex-direction: column;
}
.summary-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 8rpx;
}
.summary-value {
  font-size: 60rpx;
  font-weight: 700;
  color: #ffffff;
}
.summary-sub {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}
.sub-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 4rpx;
}
.sub-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}
.withdraw-btn {
  width: 100%;
  height: 80rpx;
  background-color: rgba(255,255,255,0.25);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: 2rpx solid rgba(255,255,255,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}
.withdraw-btn[disabled] {
  opacity: 0.6;
}

/* 筛选行 */
.filter-row {
  background-color: #ffffff;
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  margin-bottom: 4rpx;
}
.month-picker {
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333333;
}
.type-tabs {
  display: flex;
  margin-left: 20rpx;
}
.type-tab {
  padding: 10rpx 20rpx;
  font-size: 26rpx;
  color: #666666;
  border-radius: 8rpx;
  margin-right: 10rpx;
}
.tab-active {
  color: #07C160;
  font-weight: 600;
  background-color: #E8F5E9;
}

/* 流水列表 */
.income-item {
  background-color: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.income-left {
  display: flex;
  align-items: center;
}
.income-type-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  margin-right: 16rpx;
}
.icon-commission {
  background-color: #FFF8E1;
}
.icon-withdraw {
  background-color: #E3F2FD;
}
.income-info {
  display: flex;
  flex-direction: column;
}
.income-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 4rpx;
}
.income-desc {
  font-size: 22rpx;
  color: #999999;
}
.income-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}
.income-amount {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}
.amount-plus {
  color: #07C160;
}
.amount-minus {
  color: #999999;
}
.income-time {
  font-size: 22rpx;
  color: #cccccc;
}
