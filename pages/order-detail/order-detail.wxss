/* pages/order-detail/order-detail.wxss */
.page-detail { background: #f5f5f5; min-height: 100vh; padding-bottom: 140rpx; }

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, #07C160, #06AD56);
  color: #fff; padding: 40rpx 24rpx 30rpx; margin-bottom: 20rpx;
}
.status-card.cancelled {
  background: linear-gradient(135deg, #999, #777);
}
.status-header { text-align: center; }
.status-icon { font-size: 48rpx; display: block; margin-bottom: 8rpx; }
.status-text { font-size: 36rpx; font-weight: bold; }

.status-steps { display: flex; align-items: flex-start; padding: 30rpx 16rpx 0; position: relative; }
.step-item { display: flex; flex-direction: column; align-items: center; flex: 1; position: relative; }
.step-dot {
  width: 40rpx; height: 40rpx; border-radius: 50%; background: rgba(255,255,255,0.3);
  display: flex; align-items: center; justify-content: center; font-size: 20rpx; color: #fff;
  z-index: 1;
}
.step-item.done .step-dot { background: #fff; color: #07C160; }
.step-item.current .step-dot { border: 3rpx solid #fff; background: #07C160; color: #fff; }
.step-label { font-size: 22rpx; margin-top: 8rpx; opacity: 0.7; }
.step-item.done .step-label, .step-item.current .step-label { opacity: 1; }
.step-line {
  position: absolute; top: 20rpx; left: 50%; right: -50%; height: 2rpx;
  background: rgba(255,255,255,0.3); z-index: 0;
}

/* 操作提醒卡片 */
.action-alert {
  background: #FFF8E1; border-left: 6rpx solid #FF8F1F;
  border-radius: 8rpx; padding: 20rpx 24rpx; margin: 0 24rpx 16rpx;
}
.alert-content { display: flex; align-items: center; }
.alert-icon { font-size: 36rpx; margin-right: 16rpx; }
.alert-title { font-size: 28rpx; font-weight: bold; color: #FF8F1F; display: block; }
.alert-desc { font-size: 24rpx; color: #999; margin-top: 4rpx; display: block; }

/* 支付状态标签 */
.tag-unpaid { color: #FA5151; font-size: 24rpx; font-weight: bold; }
.tag-paid { color: #07C160; font-size: 24rpx; font-weight: bold; }

/* 信息行 */
.card-title { font-size: 30rpx; font-weight: bold; margin-bottom: 16rpx; }
.service-name { font-size: 30rpx; font-weight: bold; color: #333; }
.price-text { font-size: 32rpx; color: #FA5151; font-weight: bold; }
.label-text { font-size: 26rpx; color: #999; }
.copy-btn { font-size: 22rpx; color: #07C160; margin-left: 8rpx; border: 1rpx solid #07C160; padding: 2rpx 12rpx; border-radius: 4rpx; }
.price-value { font-size: 32rpx; color: #FA5151; font-weight: bold; }
.discount-text { color: #07C160; }

.info-row { display: flex; justify-content: space-between; padding: 12rpx 0; font-size: 26rpx; color: #666; border-bottom: 1rpx solid #fafafa; }
.info-row:last-child { border-bottom: none; }
.info-label { color: #999; flex-shrink: 0; margin-right: 24rpx; }
.info-row.total { border-top: 1rpx solid #f0f0f0; padding-top: 16rpx; font-weight: bold; color: #333; border-bottom: none; }

/* 师傅 */
.worker-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; background: #E8F8EF; display: flex; align-items: center; justify-content: center; font-size: 36rpx; }
.worker-name { font-size: 28rpx; font-weight: bold; color: #333; display: block; }
.worker-phone { font-size: 24rpx; color: #999; margin-top: 4rpx; display: block; }
.call-btn { padding: 10rpx 28rpx; font-size: 24rpx; border-radius: 30rpx; }

/* 订单日志 */
.log-item { display: flex; align-items: flex-start; padding: 16rpx 0; }
.log-item:not(:last-child) { border-bottom: 1rpx solid #f5f5f5; }
.log-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%; flex-shrink: 0;
  margin-right: 16rpx; margin-top: 6rpx;
}
.log-dot.user { background: #1989FA; }
.log-dot.system { background: #07C160; }
.log-dot.worker { background: #FF8F1F; }
.log-content { flex: 1; }
.log-text { font-size: 26rpx; color: #333; display: block; }
.log-time { font-size: 22rpx; color: #ccc; margin-top: 4rpx; display: block; }

/* 底部 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0; padding: 20rpx 24rpx;
  background: #fff; border-top: 1rpx solid #eee;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

/* 全局通用 */
.card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin: 0 24rpx 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.empty-page { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 200rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: #999; }
.flex { display: flex; }
.flex-center { display: flex; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-1 { flex: 1; }
.btn-primary { background: linear-gradient(135deg, #07C160, #06AD56); color: #fff; padding: 20rpx; border-radius: 40rpx; text-align: center; font-size: 28rpx; font-weight: bold; }
.btn-outline { border: 2rpx solid #ddd; color: #666; padding: 20rpx; border-radius: 40rpx; text-align: center; font-size: 28rpx; }
