/* pages/order-detail/order-detail.wxss */
.detail-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 状态头部 */
.status-header {
  background-color: #ffffff;
  padding: 50rpx 0;
  display: flex;
  justify-content: center;
}
.status-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}
.tag-pending.status-circle { background-color: #FF9800; }
.tag-accepted.status-circle { background-color: #1976D2; }
.tag-doing.status-circle { background-color: #388E3C; }
.tag-done.status-circle { background-color: #7B1FA2; }
.tag-cancel.status-circle { background-color: #999999; }

/* 信息卡片 */
.info-card {
  background-color: #ffffff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}
.info-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}
.info-label {
  font-size: 26rpx;
  color: #999999;
}
.info-value {
  font-size: 26rpx;
  color: #333333;
  text-align: right;
  max-width: 400rpx;
}
.fee {
  color: #FA5151;
  font-weight: 600;
}
.link {
  color: #1976D2;
}

/* 完工凭证 */
.proof-image {
  width: 100%;
  border-radius: 12rpx;
}

/* 底部操作 */
.bottom-spacer {
  height: 100rpx;
}
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  display: flex;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  gap: 16rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}
.bottom-btn {
  flex: 1;
  height: 84rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.accept-btn { background-color: #07C160; color: #fff; }
.contact-btn { background-color: #E3F2FD; color: #1976D2; }
.done-btn { background-color: #FF9800; color: #fff; }

.loading-state {
  display: flex;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
}
