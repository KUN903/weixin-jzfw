<!-- pages/order-detail/order-detail.wxml - 工单详情 -->
<view class="detail-container" wx:if="{{!loading && order}}">

  <!-- 状态头部 -->
  <view class="status-header">
    <view class="status-circle {{statusClass}}">{{statusText}}</view>
  </view>

  <!-- 订单信息卡片 -->
  <view class="info-card">
    <view class="info-title">订单信息</view>
    <view class="info-row">
      <text class="info-label">工单号</text>
      <text class="info-value">{{order.order_no || order.id}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">服务类型</text>
      <text class="info-value">{{order.service_name}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">预约时间</text>
      <text class="info-value">{{order.appointment_time || order.create_time}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">服务费用</text>
      <text class="info-value fee">¥{{order.price || '0.00'}}</text>
    </view>
  </view>

  <!-- 客户信息卡片 -->
  <view class="info-card">
    <view class="info-title">客户信息</view>
    <view class="info-row">
      <text class="info-label">客户姓名</text>
      <text class="info-value">{{order.customer_name || '--'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">联系电话</text>
      <text class="info-value link" bindtap="onContact">{{order.customer_phone || '--'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">服务地址</text>
      <text class="info-value">{{order.address}}</text>
    </view>
    <view class="info-row" wx:if="{{order.remark}}">
      <text class="info-label">客户备注</text>
      <text class="info-value">{{order.remark}}</text>
    </view>
  </view>

  <!-- 完工凭证 -->
  <view class="info-card" wx:if="{{order.proof_url}}">
    <view class="info-title">完工凭证</view>
    <image class="proof-image" src="{{order.proof_url}}" mode="widthFix" bindtap="onPreviewProof"/>
  </view>

  <!-- 底部分隔 -->
  <view class="bottom-spacer"></view>

  <!-- 底部操作栏 -->
  <view class="bottom-actions" wx:if="{{order.status !== 'done' && order.status !== 'cancelled'}}">
    <button wx:if="{{order.status === 'pending'}}" class="bottom-btn accept-btn" bindtap="onAccept">接单</button>
    <button wx:if="{{order.status === 'accepted' || order.status === 'doing'}}" class="bottom-btn contact-btn" bindtap="onContact">📞 联系客户</button>
    <button wx:if="{{order.status === 'accepted' || order.status === 'doing'}}" class="bottom-btn done-btn" bindtap="onUploadProof">完工上传凭证</button>
  </view>

</view>

<!-- 加载中 -->
<view class="loading-state" wx:if="{{loading}}">
  <text>加载中...</text>
</view>

<!-- 加载失败 -->
<view class="empty-state" wx:if="{{!loading && !order}}">
  <text class="empty-icon">📋</text>
  <text class="empty-text">工单信息加载失败</text>
</view>
