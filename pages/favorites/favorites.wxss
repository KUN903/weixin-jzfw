/* favorites */
.page-favorites { background: #f5f5f5; min-height: 100vh; padding: 20rpx; }
.fav-item { display: flex; background: #fff; border-radius: 16rpx; padding: 20rpx; margin-bottom: 16rpx; align-items: center; }
.fav-cover { width: 140rpx; height: 120rpx; background: linear-gradient(135deg, #E8F8EF, #D4F5E0); border-radius: 12rpx; display: flex; align-items: center; justify-content: center; font-size: 36rpx; font-weight: bold; color: #07C160; margin-right: 20rpx; }
.fav-info { flex: 1; }
.fav-name { font-size: 28rpx; font-weight: 500; color: #333; }
.price-symbol { font-size: 24rpx; color: #FA5151; } .price-value { font-size: 36rpx; color: #FA5151; font-weight: bold; } .price-unit { font-size: 22rpx; color: #999; }
