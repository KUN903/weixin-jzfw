<!-- pages/address-edit/address-edit.wxml -->
<view class="page-addr-edit">
  <view class="form-section">
    <text class="section-label">收货信息</text>
  </view>
  <view class="form-group">
    <text class="form-label">联系人</text>
    <input class="form-input" placeholder="请输入联系人姓名" value="{{contactName}}" bindinput="onInput" data-field="contactName" />
  </view>
  <view class="form-group">
    <text class="form-label">手机号</text>
    <input class="form-input" type="number" maxlength="11" placeholder="请输入11位手机号" value="{{contactPhone}}" bindinput="onInput" data-field="contactPhone" />
  </view>

  <view class="form-section">
    <text class="section-label">所在地区</text>
    <text class="location-btn" bindtap="onAutoLocate">{{locating ? '定位中...' : '📍 获取当前位置'}}</text>
  </view>
  <view class="form-row">
    <input class="form-input-third" placeholder="省份" value="{{province}}" bindinput="onInput" data-field="province" />
    <input class="form-input-third" placeholder="城市" value="{{city}}" bindinput="onInput" data-field="city" />
    <input class="form-input-third" placeholder="区/县" value="{{district}}" bindinput="onInput" data-field="district" />
  </view>

  <view class="form-group">
    <text class="form-label">详细地址</text>
    <textarea class="form-textarea" placeholder="街道/小区/门牌号（如 XX路XX号XX室）" value="{{detail}}" bindinput="onInput" data-field="detail" />
  </view>

  <view class="form-group">
    <text class="form-label">设为默认</text>
    <switch checked="{{isDefault}}" bindchange="onSwitchDefault" color="#07C160" />
  </view>

  <view class="save-btn {{saving ? 'btn-disabled' : 'btn-primary'}}" bindtap="onSave">
    <text wx:if="{{!saving}}">保存地址</text>
    <text wx:else>保存中...</text>
  </view>
</view>
