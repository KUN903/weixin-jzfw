/* address-edit */
.page-addr-edit { background: #f5f5f5; min-height: 100vh; padding-bottom: 40rpx; }

.form-section { padding: 32rpx 24rpx 16rpx; display: flex; align-items: center; justify-content: space-between; }
.section-label { font-size: 26rpx; color: #999; font-weight: 500; }
.location-btn { font-size: 24rpx; color: #07C160; padding: 6rpx 16rpx; border: 1rpx solid #07C160; border-radius: 20rpx; }

.form-group { background: #fff; display: flex; align-items: center; padding: 28rpx 24rpx; border-bottom: 1rpx solid #f0f0f0; }
.form-group:first-of-type { border-radius: 16rpx 16rpx 0 0; }
.form-label { width: 150rpx; font-size: 28rpx; color: #333; flex-shrink: 0; }
.form-input { flex: 1; font-size: 28rpx; color: #333; }
.form-textarea { flex: 1; font-size: 28rpx; min-height: 120rpx; padding: 12rpx 0; line-height: 1.6; }

.form-row {
  display: flex; background: #fff; padding: 20rpx 24rpx;
  border-top: 1rpx solid #f0f0f0; border-bottom: 1rpx solid #f0f0f0;
}
.form-input-third {
  flex: 1; font-size: 28rpx; color: #333; text-align: center;
  background: #f8f8f8; border-radius: 10rpx; padding: 18rpx 12rpx; margin: 0 8rpx;
}

.save-btn { margin: 50rpx 24rpx; text-align: center; border-radius: 50rpx; padding: 28rpx; font-size: 32rpx; color: #fff; }
.btn-primary { background: linear-gradient(135deg, #07C160, #06AD56); box-shadow: 0 6rpx 20rpx rgba(7,193,96,0.3); }
.btn-disabled { background: #ccc; }
