/* search */
.page-search { background: #fff; min-height: 100vh; padding: 20rpx; }
.search-bar { display: flex; align-items: center; margin-bottom: 24rpx; }
.search-box { flex: 1; display: flex; align-items: center; background: #f5f5f5; border-radius: 40rpx; padding: 14rpx 24rpx; }
.search-icon { font-size: 28rpx; margin-right: 10rpx; }
.search-input { flex: 1; font-size: 28rpx; }
.search-btn { font-size: 28rpx; color: #07C160; margin-left: 16rpx; flex-shrink: 0; }
.search-block { margin-bottom: 32rpx; }
.block-title { font-size: 30rpx; font-weight: bold; color: #333; }
.clear-btn { font-size: 24rpx; color: #999; }
.keyword-row { display: flex; flex-wrap: wrap; }
.keyword { background: #f5f5f5; color: #666; font-size: 26rpx; padding: 10rpx 24rpx; border-radius: 30rpx; margin: 0 12rpx 12rpx 0; }
.result-item { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.res-cover { width: 120rpx; height: 110rpx; background: linear-gradient(135deg, #E8F8EF, #D4F5E0); border-radius: 12rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: bold; color: #07C160; margin-right: 20rpx; }
.res-info { flex: 1; }
.res-name { font-size: 28rpx; font-weight: 500; color: #333; display: block; margin-bottom: 8rpx; }
