/* pages/category/category.wxss - 分类页 */
.page-category {
  display: flex;
  height: 100vh;
  background: #fff;
}
.category-sidebar {
  width: 180rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}
.sidebar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #666;
  position: relative;
}
.sidebar-item.active {
  background: #fff;
  color: #07C160;
  font-weight: bold;
}
.sidebar-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 30rpx;
  bottom: 30rpx;
  width: 6rpx;
  background: #07C160;
  border-radius: 0 3rpx 3rpx 0;
}
.sidebar-icon { font-size: 30rpx; margin-bottom: 6rpx; }
.sidebar-name { font-size: 24rpx; }

.service-list { flex: 1; overflow: hidden; padding: 12rpx; }
.list-header { padding: 16rpx 8rpx 8rpx; }
.list-title { font-size: 30rpx; font-weight: bold; color: #333; }
.loading-hint { text-align: center; padding: 40rpx; color: #999; font-size: 26rpx; }

.service-item {
  display: flex;
  padding: 16rpx 8rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.service-cover-small {
  width: 160rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #E8F8EF, #D4F5E0);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
}
.cover-placeholder { font-size: 36rpx; font-weight: bold; color: #07C160; }
.cover-image { width: 100%; height: 100%; position: absolute; top: 0; left: 0; }
.service-body { flex: 1; display: flex; flex-direction: column; justify-content: center; }
.service-name { font-size: 28rpx; font-weight: 500; color: #333; margin-bottom: 8rpx; }
.service-tags { margin-bottom: 6rpx; }
.service-sales { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.price-symbol { font-size: 22rpx; color: #FA5151; }
.price-value { font-size: 36rpx; color: #FA5151; font-weight: bold; }
.price-unit { font-size: 22rpx; color: #999; }
.price-original { font-size: 22rpx; color: #ccc; text-decoration: line-through; margin-left: 8rpx; }
