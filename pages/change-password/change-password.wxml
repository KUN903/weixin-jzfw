<!-- pages/change-password/change-password.wxml -->
<view class="cp-container">
  <view class="form-card">
    <view class="form-item">
      <text class="form-label">原密码</text>
      <input class="form-input" type="password" placeholder="请输入原密码" placeholder-class="ph" value="{{oldPassword}}" bindinput="onOldInput"/>
    </view>
    <view class="form-item">
      <text class="form-label">新密码</text>
      <input class="form-input" type="password" placeholder="请输入新密码（至少6位）" placeholder-class="ph" value="{{newPassword}}" bindinput="onNewInput"/>
    </view>
    <view class="form-item">
      <text class="form-label">确认密码</text>
      <input class="form-input" type="password" placeholder="请再次输入新密码" placeholder-class="ph" value="{{confirmPassword}}" bindinput="onConfirmInput"/>
    </view>
  </view>

  <view class="submit-area">
    <button class="submit-btn" bindtap="onSubmit">确认修改</button>
  </view>
</view>
