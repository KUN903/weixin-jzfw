/* pages/service-detail/service-detail.wxss */
.page-detail { background: #f5f5f5; height: 100vh; display: flex; flex-direction: column; }
.detail-scroll { flex: 1; }

/* 封面 */
.cover-section {
  height: 400rpx;
  position: relative;
  overflow: hidden;
}
.cover-image {
  width: 100%;
  height: 100%;
}
.cover-bg {
  height: 100%;
  background: linear-gradient(135deg, #07C160, #06AD56, #059B4A);
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

/* 基本信息 */
.basic-info {
  margin-top: -20rpx;
  position: relative;
  z-index: 2;
  border-radius: 24rpx 24rpx 0 0;
}
.service-title { font-size: 34rpx; font-weight: bold; color: #333; }
.price-big { font-size: 48rpx; color: #FA5151; font-weight: bold; }
.price-unit { font-size: 26rpx; color: #999; }
.price-original { font-size: 26rpx; color: #ccc; text-decoration: line-through; margin-left: 8rpx; }
.meta-text { font-size: 24rpx; color: #999; }

/* 卡片标题 */
.card { background: #fff; margin: 20rpx; border-radius: 16rpx; padding: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.card-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; display: block; }

/* 规格选择 */
.spec-group { margin-bottom: 24rpx; }
.spec-label { font-size: 26rpx; color: #666; margin-bottom: 12rpx; display: block; }
.spec-options { display: flex; flex-wrap: wrap; }
.spec-option {
  background: #f5f5f5;
  color: #333;
  font-size: 26rpx;
  padding: 12rpx 28rpx;
  border-radius: 8rpx;
  margin: 0 16rpx 12rpx 0;
  border: 2rpx solid transparent;
}
.spec-option.active { background: rgba(7,193,96,0.08); color: #07C160; border-color: #07C160; }

/* 描述 */
.desc-text { font-size: 28rpx; color: #666; line-height: 1.8; }

/* 服务流程 */
.flow-list { padding-left: 8rpx; }
.flow-item { display: flex; align-items: center; padding: 14rpx 0; }
.flow-dot {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background: #07C160; color: #fff; font-size: 22rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-right: 16rpx;
}
.flow-text { font-size: 28rpx; color: #333; }

/* 注意事项 */
.notice-text { font-size: 26rpx; color: #999; line-height: 1.8; }

/* 评价 */
.more-link { font-size: 26rpx; color: #07C160; }
.review-item { padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.review-avatar { font-size: 36rpx; margin-right: 10rpx; }
.review-nick { font-size: 26rpx; color: #666; }
.review-rating { font-size: 24rpx; color: #FFC300; }
.review-content { font-size: 28rpx; color: #333; margin-top: 10rpx; line-height: 1.6; }
.review-date { font-size: 22rpx; color: #ccc; margin-top: 8rpx; }

/* 底部操作栏 */
.bottom-bar {
  display: flex; align-items: center; padding: 16rpx 24rpx;
  background: #fff; border-top: 1rpx solid #eee;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
.bottom-left { margin-right: 16rpx; }
.favorite-btn {
  display: flex; flex-direction: column; align-items: center;
  font-size: 36rpx; padding: 8rpx;
}
.bottom-order-btn { flex: 1; text-align: center; padding: 24rpx; border-radius: 50rpx; }

/* ========== 师傅详情样式 ========== */
/* 师傅头部 */
.worker-header {
  position: relative;
  margin-bottom: 20rpx;
}
.worker-header-bg {
  height: 280rpx;
  background: linear-gradient(135deg, #1989FA, #0D6EDD);
}
.worker-header-body {
  display: flex;
  align-items: flex-end;
  padding: 0 28rpx 24rpx;
  margin-top: -60rpx;
  position: relative;
  z-index: 2;
}
.worker-avatar-large {
  width: 140rpx; height: 140rpx; border-radius: 50%;
  background: #fff; border: 6rpx solid #fff; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  display: flex; align-items: center; justify-content: center;
  font-size: 64rpx; flex-shrink: 0;
}
.worker-header-info {
  margin-left: 20rpx; padding-bottom: 8rpx; color: #fff;
}
.worker-header-name {
  display: flex; align-items: center;
}
.worker-name-large {
  font-size: 36rpx; font-weight: bold;
}
.worker-verify {
  font-size: 22rpx; background: rgba(255,255,255,0.25);
  border-radius: 20rpx; padding: 4rpx 14rpx; margin-left: 12rpx;
}
.worker-area {
  font-size: 24rpx; opacity: 0.85; margin-top: 6rpx; display: block;
}

/* 师傅数据统计卡 */
.worker-stats-card {
  margin-top: -12rpx; position: relative; z-index: 1;
}
.stat-row { display: flex; }
.stat-col { flex: 1; display: flex; flex-direction: column; align-items: center; }
.stat-num { font-size: 32rpx; font-weight: bold; color: #333; }
.stat-label { font-size: 22rpx; color: #999; margin-top: 6rpx; }
.stat-divider { width: 1rpx; background: #eee; align-self: stretch; margin: 8rpx 0; }

/* 师傅服务列表项 */
.worker-service-item {
  display: flex; align-items: center; padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.worker-service-item:last-child { border-bottom: none; }
.ws-cover {
  width: 120rpx; height: 100rpx; border-radius: 12rpx;
  background: linear-gradient(135deg, #E8F8EF, #D4F5E0);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; overflow: hidden;
}
.ws-cover-img { width: 100%; height: 100%; }
.ws-cover-text { font-size: 32rpx; font-weight: bold; color: #07C160; }
.ws-body { flex: 1; margin-left: 16rpx; }
.ws-name { font-size: 28rpx; font-weight: 500; color: #333; display: block; }
.ws-tags { margin-top: 6rpx; display: flex; }
.ws-price-row { margin-top: 8rpx; display: flex; align-items: baseline; }
.price-symbol { font-size: 22rpx; color: #FA5151; }
.price-value { font-size: 30rpx; color: #FA5151; font-weight: bold; }
.price-unit { font-size: 22rpx; color: #999; margin-left: 2rpx; }
.price-original { font-size: 22rpx; color: #ccc; text-decoration: line-through; margin-left: 8rpx; }
.ws-btn {
  background: linear-gradient(135deg, #07C160, #06AD56); color: #fff;
  font-size: 24rpx; padding: 10rpx 24rpx; border-radius: 30rpx;
  flex-shrink: 0; margin-left: 12rpx;
}

/* 电话按钮 */
.phone-btn {
  display: flex; flex-direction: column; align-items: center; padding: 8rpx;
}

/* 标签 */
.tag { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 6rpx; display: inline-block; }
.tag-primary { background: rgba(7,193,96,0.1); color: #07C160; margin-right: 8rpx; }
.tag-hot { background: rgba(250,81,81,0.1); color: #FA5151; }
