/* pages/mine/mine.wxss */
.page-mine { background: #f5f5f5; min-height: 100vh; }

/* 用户头部 */
.user-header {
  background: linear-gradient(135deg, #07C160, #06AD56);
  display: flex; align-items: center; padding: 80rpx 32rpx 48rpx;
}
.user-avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%; background: rgba(255,255,255,0.3);
  display: flex; align-items: center; justify-content: center; font-size: 52rpx;
  overflow: hidden; margin-right: 24rpx; flex-shrink: 0;
}
.user-avatar image { width: 100%; height: 100%; }
.user-info { color: #fff; flex: 1; }
.user-name { font-size: 36rpx; font-weight: bold; display: block; }
.user-sub { font-size: 24rpx; opacity: 0.8; margin-top: 6rpx; display: block; }

/* 角色标签 */
.role-tag {
  display: flex; align-items: center; background: rgba(255,255,255,0.2);
  border-radius: 30rpx; padding: 12rpx 20rpx; margin-left: 16rpx;
}
.role-tag-text { font-size: 24rpx; color: #fff; margin: 0 8rpx; }
.role-tag-arrow { font-size: 18rpx; color: rgba(255,255,255,0.6); }

/* 角色选择器 */
.role-picker {
  margin: -20rpx 24rpx 20rpx; background: #fff; border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08); overflow: hidden;
  position: relative; z-index: 1;
}
.role-picker-item {
  display: flex; align-items: center; padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.role-picker-item:last-child { border-bottom: none; }
.role-picker-item.active { background: rgba(7,193,96,0.04); }
.role-picker-icon { font-size: 40rpx; margin-right: 20rpx; }
.role-picker-info { flex: 1; }
.role-picker-name { font-size: 28rpx; color: #333; font-weight: 500; display: block; }
.role-picker-desc { font-size: 22rpx; color: #999; margin-top: 4rpx; display: block; }
.role-picker-check { font-size: 32rpx; }

/* 数据统计 */
.stats-row { display: flex; background: #fff; margin: -28rpx 24rpx 20rpx; border-radius: 16rpx; padding: 28rpx 0; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06); position: relative; z-index: 1; }
.stat-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.stat-number { font-size: 36rpx; font-weight: bold; color: #333; }
.stat-label { font-size: 22rpx; color: #999; margin-top: 6rpx; }

/* 资产卡片 */
.asset-card { display: flex; padding: 32rpx; margin: 0 24rpx; }
.asset-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.asset-value { font-size: 32rpx; font-weight: bold; color: #333; }
.asset-label { font-size: 24rpx; color: #999; margin-top: 6rpx; }
.asset-divider { width: 1rpx; background: #eee; align-self: stretch; }

/* 菜单 */
.menu-section { margin-top: 24rpx; }
.menu-title { font-size: 26rpx; color: #999; padding: 0 32rpx; margin-bottom: 8rpx; }
.menu-list { background: #fff; }
.menu-item {
  display: flex; align-items: center; padding: 28rpx 32rpx; border-bottom: 1rpx solid #f5f5f5;
}
.menu-icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-label { flex: 1; font-size: 28rpx; color: #333; }
.menu-arrow { font-size: 32rpx; color: #ccc; }
