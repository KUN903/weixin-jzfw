<!-- pages/login/login.wxml - 统一登录页（优化版） -->
<view class="login-page">

  <!-- ========== 顶部绿色品牌区（40%） ========== -->
  <view class="brand-area">
    <view class="brand-icon">🏠</view>
    <text class="brand-title">家政上门服务平台</text>
    <text class="brand-desc">专业家政 一键预约</text>
  </view>

  <!-- ========== 角色选择（跨绿白分界） ========== -->
  <view class="role-row">
    <view class="role-btn role-customer {{role === 'user' ? 'role-active' : ''}}" bindtap="onRoleChange" data-role="user">
      我是客户
    </view>
    <view class="role-btn role-worker {{role === 'worker' ? 'role-active' : ''}}" bindtap="onRoleChange" data-role="worker">
      我是师傅
    </view>
  </view>
  <text class="guide-text">请先选择您的身份，再进行微信授权登录。</text>

  <!-- ========== 登录表单区 ========== -->
  <view class="login-area">

    <!-- 客户：微信一键登录 -->
    <block wx:if="{{role === 'user'}}">
      <text class="login-hint">微信授权即可快速登录，无需注册</text>
      <button class="login-button" bindtap="onWechatLogin" disabled="{{loading}}"
              hover-class="btn-press" hover-stay-time="100">
        <text class="btn-icon" wx:if="{{!loading}}">🔔</text>
        <text wx:if="{{!loading}}">微信一键登录</text>
        <text wx:else>登录中...</text>
      </button>
    </block>

    <!-- 师傅：手机号+密码登录 -->
    <block wx:if="{{role === 'worker'}}">
      <view class="input-group">
        <text class="input-label">手机号</text>
        <input class="input-field" type="number" maxlength="11" placeholder="请输入手机号" placeholder-class="ph" value="{{phone}}" bindinput="onPhoneInput"/>
      </view>
      <view class="input-group">
        <text class="input-label">密码</text>
        <input class="input-field" type="password" maxlength="20" placeholder="请输入密码" placeholder-class="ph" value="{{password}}" bindinput="onPasswordInput"/>
      </view>
      <button class="login-button" bindtap="onWorkerLogin" disabled="{{loading}}"
              hover-class="btn-press" hover-stay-time="100">
        {{loading ? '登录中...' : '登录'}}
      </button>
      <text class="switch-hint" bindtap="onRoleChange" data-role="user">返回客户登录</text>
    </block>

  </view>

  <!-- ========== 底部协议 ========== -->
  <text class="footer-text">登录即表示同意《用户协议》和《隐私政策》</text>

</view>
