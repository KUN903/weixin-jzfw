/* pages/login/login.wxss - 统一登录页（优化版） */

/* ============================================
   布局策略：
   - 绿色区 40vh，内容垂直居中
   - 角色按钮跨绿白分界（负 margin）
   - 所有元素紧密垂直排列，无留白断裂
   - 底部安全区适配
   ============================================ */

.login-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
}

/* ========== 1. 品牌区（40vh 绿色渐变） ========== */
.brand-area {
  width: 100%;
  height: 40vh;
  background: linear-gradient(180deg, #07C160 0%, #05B855 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: 40rpx;
}
.brand-icon {
  font-size: 80rpx;
  line-height: 1;
  margin-bottom: 16rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.1));
}
.brand-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}
.brand-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  letter-spacing: 8rpx;
}

/* ========== 2. 角色选择（跨分界线） ========== */
.role-row {
  display: flex;
  gap: 24rpx;
  margin-top: -40rpx;      /* 上探绿色区边缘 */
  margin-bottom: 20rpx;
  padding: 0 60rpx;
  width: 100%;
  box-sizing: border-box;
  justify-content: center;
}

.role-btn {
  flex: 1;
  max-width: 260rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

/* 我是客户：白底绿边绿字 */
.role-customer {
  background-color: #ffffff;
  color: #07C160;
  border: 3rpx solid #07C160;
}
.role-customer.role-active {
  background-color: #07C160;
  color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(7,193,96,0.35);
}

/* 我是师傅：绿色填充白字 */
.role-worker {
  background-color: #07C160;
  color: #ffffff;
}
.role-worker.role-active {
  box-shadow: 0 6rpx 20rpx rgba(7,193,96,0.35);
  transform: scale(1.03);
}

/* 未选中态淡化 */
.role-btn:not(.role-active) {
  opacity: 0.7;
}
.role-customer:not(.role-active) {
  background-color: #ffffff;
  color: #07C160;
}
.role-worker:not(.role-active) {
  background-color: #e8f8ee;
  color: #07C160;
}

.guide-text {
  font-size: 24rpx;
  color: #aaaaaa;
  margin-bottom: 32rpx;
}

/* ========== 3. 登录表单区 ========== */
.login-area {
  width: 630rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-hint {
  font-size: 24rpx;
  color: #aaaaaa;
  margin-bottom: 20rpx;
}

/* 输入框 */
.input-group {
  width: 100%;
  margin-bottom: 24rpx;
}
.input-label {
  display: block;
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
  margin-bottom: 10rpx;
}
.input-field {
  width: 100%;
  height: 88rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333333;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border 0.2s;
}
.input-field:focus {
  border-color: #07C160;
  background-color: #ffffff;
}
.ph {
  color: #cccccc;
}

/* 登录按钮（共用） */
.login-button {
  width: 630rpx;
  height: 100rpx;
  background-color: #07C160;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(7,193,96,0.3);
  transition: all 0.15s ease;
  line-height: 100rpx;
}
.login-button::after {
  border: none;
}
.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}
.btn-press {
  transform: scale(0.97);
  opacity: 0.85;
  box-shadow: 0 4rpx 12rpx rgba(7,193,96,0.2);
}

/* 返回客户登录链接 */
.switch-hint {
  margin-top: 28rpx;
  font-size: 24rpx;
  color: #999999;
}

/* ========== 4. 底部协议 ========== */
.footer-text {
  margin-top: auto;
  padding-top: 40rpx;
  padding-bottom: env(safe-area-inset-bottom, 40rpx);
  font-size: 22rpx;
  color: #cccccc;
  text-align: center;
}
