<!-- pages/today-orders/today-orders.wxml - 今日工单 -->
<view class="today-container">

  <!-- 顶部统计条 -->
  <view class="today-summary">
    <view class="summary-item">
      <text class="summary-num">{{orders.length}}</text>
      <text class="summary-label">今日工单</text>
    </view>
    <view class="summary-divider"></view>
    <view class="summary-item">
      <text class="summary-num {{pendingCount > 0 ? 'highlight' : ''}}">{{pendingCount}}</text>
      <text class="summary-label">待接单</text>
    </view>
    <view class="summary-divider"></view>
    <view class="summary-item">
      <text class="summary-num">{{doingCount}}</text>
      <text class="summary-label">服务中</text>
    </view>
  </view>

  <!-- 工单列表 -->
  <view wx:if="{{orders.length > 0}}" class="order-list">
    <view class="order-card" wx:for="{{orders}}" wx:key="id" bindtap="onOrderTap" data-id="{{item.id}}">
      <!-- 订单头部 -->
      <view class="order-header">
        <text class="order-id">工单号：{{item.order_no || item.id}}</text>
        <text class="tag {{item.statusClass}}">{{item.statusText}}</text>
      </view>
      <!-- 订单信息 -->
      <view class="order-body">
        <view class="order-row">
          <text class="order-label">服务类型</text>
          <text class="order-value">{{item.service_name}}</text>
        </view>
        <view class="order-row">
          <text class="order-label">预约时间</text>
          <text class="order-value">{{item.timeText}}</text>
        </view>
        <view class="order-row">
          <text class="order-label">客户地址</text>
          <text class="order-value">{{item.addressShort}}</text>
        </view>
        <view class="order-row">
          <text class="order-label">客户姓名</text>
          <text class="order-value">{{item.customer_name || '--'}}</text>
        </view>
      </view>
      <!-- 操作按钮区 -->
      <view class="order-actions" wx:if="{{item.status !== 'done' && item.status !== 'cancelled'}}">
        <!-- 待接单：接单 + 拒单 -->
        <button wx:if="{{item.status === 'pending'}}" class="action-btn accept-btn" catchtap="onAccept" data-id="{{item.id}}">接单</button>
        <!-- 已接单/服务中：联系客户 -->
        <button wx:if="{{item.status === 'accepted' || item.status === 'doing'}}" class="action-btn contact-btn" catchtap="onContact" data-phone="{{item.customer_phone}}">
          <text>📞 联系客户</text>
        </button>
        <!-- 已接单/服务中：完工上传 -->
        <button wx:if="{{item.status === 'accepted' || item.status === 'doing'}}" class="action-btn done-btn" catchtap="onUploadProof" data-id="{{item.id}}">完工上传凭证</button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <text class="empty-icon">📋</text>
    <text class="empty-text">今日暂无工单</text>
    <text class="empty-sub">新的工单将在这里显示</text>
  </view>

  <!-- 查看全部工单入口 -->
  <view class="all-orders-entry" bindtap="onAllOrders">
    <text>查看全部历史工单</text>
    <text class="entry-arrow">›</text>
  </view>

</view>
