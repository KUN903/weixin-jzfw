<!-- pages/all-orders/all-orders.wxml - 全部工单 -->
<view class="all-orders-container">

  <!-- 日期筛选 -->
  <view class="filter-bar">
    <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
      <view class="date-picker {{startDate ? '' : 'date-placeholder'}}">
        {{startDate || '开始日期'}}
      </view>
    </picker>
    <text class="filter-sep">至</text>
    <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
      <view class="date-picker {{endDate ? '' : 'date-placeholder'}}">
        {{endDate || '结束日期'}}
      </view>
    </picker>
    <view class="filter-btn" bindtap="onApplyFilter">筛选</view>
  </view>

  <!-- 状态 Tab -->
  <scroll-view scroll-x class="status-tabs">
    <view class="status-tab {{activeTab === item.key ? 'tab-active' : ''}}" 
          wx:for="{{tabs}}" wx:key="key" 
          bindtap="onTabChange" data-key="{{item.key}}">
      {{item.name}}
    </view>
  </scroll-view>

  <!-- 工单列表 -->
  <view wx:if="{{orders.length > 0}}" class="order-list">
    <view class="order-card" wx:for="{{orders}}" wx:key="id" bindtap="onOrderTap" data-id="{{item.id}}">
      <view class="order-header">
        <text class="order-id">工单号：{{item.order_no || item.id}}</text>
        <text class="tag {{item.statusClass}}">{{item.statusText}}</text>
      </view>
      <view class="order-body">
        <view class="order-row">
          <text class="order-label">服务类型</text>
          <text class="order-value">{{item.service_name}}</text>
        </view>
        <view class="order-row">
          <text class="order-label">预约时间</text>
          <text class="order-value">{{item.timeText}}</text>
        </view>
        <view class="order-row">
          <text class="order-label">客户地址</text>
          <text class="order-value">{{item.addressShort}}</text>
        </view>
        <view class="order-row">
          <text class="order-label">收入</text>
          <text class="order-value income-value">¥{{item.commission || item.price || '0.00'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <text class="empty-icon">📁</text>
    <text class="empty-text">{{activeTab === 'all' ? '暂无工单记录' : '暂无此类工单'}}</text>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{orders.length > 0}}">
    <text wx:if="{{loading}}">加载中...</text>
    <text wx:elif="{{!hasMore}}">没有更多了</text>
  </view>

</view>
