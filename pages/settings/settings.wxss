/* pages/settings/settings.wxss */
.settings-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.version-info {
  display: flex;
  align-items: center;
}
.version-text {
  color: #999999;
  font-size: 26rpx;
  margin-right: 8rpx;
}

/* 底部账号操作 */
.account-actions {
  margin-top: 60rpx;
  padding: 0 30rpx;
}
.action-btn {
  width: 100%;
  height: 90rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 24rpx;
}
.switch-btn {
  background-color: #f5f5f5;
  color: #666666;
}
.switch-btn:active {
  background-color: #e8e8e8;
}
.logout-btn {
  background-color: #ffffff;
  color: #FA5151;
  border: 2rpx solid #FA5151;
}
.logout-btn:active {
  background-color: #FFF0F0;
}
