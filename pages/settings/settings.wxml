<!-- pages/settings/settings.wxml - 设置页 -->
<view class="settings-container">

  <!-- 常规设置列表 -->
  <view class="section-card">
    <view class="list-item" bindtap="onChangePassword">
      <text class="list-item-text">修改登录密码</text>
      <text class="list-item-arrow">›</text>
    </view>
    <view class="divider"></view>
    <view class="list-item" bindtap="onChangePhone">
      <text class="list-item-text">更换绑定手机号</text>
      <text class="list-item-arrow">›</text>
    </view>
    <view class="divider"></view>
    <view class="list-item">
      <text class="list-item-text">消息通知</text>
      <switch checked="{{notifyEnabled}}" bindchange="onNotifySwitch" color="#07C160"/>
    </view>
    <view class="divider"></view>
    <view class="list-item" bindtap="onPrivacy">
      <text class="list-item-text">隐私权限设置</text>
      <text class="list-item-arrow">›</text>
    </view>
    <view class="divider"></view>
    <view class="list-item" bindtap="onCheckVersion">
      <text class="list-item-text">版本检测更新</text>
      <view class="version-info">
        <text class="version-text">v{{version}}</text>
        <text class="list-item-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 底部账号操作区 -->
  <view class="account-actions">
    <button class="action-btn switch-btn" bindtap="onSwitchAccount">切换师傅账号</button>
    <button class="action-btn logout-btn" bindtap="onLogout">退出登录</button>
  </view>

</view>
