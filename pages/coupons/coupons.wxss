/* coupons */
.page-coupons { background: #f5f5f5; min-height: 100vh; padding: 20rpx; }
.coupon-item { display: flex; background: #fff; border-radius: 16rpx; overflow: hidden; margin-bottom: 16rpx; }
.coupon-item.used { opacity: 0.6; }
.coupon-item.expired { opacity: 0.4; }
.coupon-left { width: 200rpx; background: linear-gradient(135deg, #FF6B6B, #FA5151); color: #fff; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 32rpx 0; }
.coupon-value { font-size: 48rpx; font-weight: bold; }
.coupon-condition { font-size: 22rpx; margin-top: 6rpx; }
.coupon-right { flex: 1; padding: 28rpx 24rpx; display: flex; flex-direction: column; justify-content: center; }
.coupon-name { font-size: 30rpx; font-weight: bold; color: #333; }
.coupon-expire { font-size: 24rpx; color: #999; margin-top: 8rpx; }
.coupon-status { font-size: 22rpx; color: #ccc; margin-top: 8rpx; }
