<!-- pages/coupons/coupons.wxml -->
<view class="page-coupons">
  <view wx:if="{{loading}}" class="loading-hint">加载中...</view>
  <view wx:elif="{{coupons.length === 0}}" class="empty-state"><text class="icon">🎫</text><text class="text">暂无优惠券</text></view>
  <view class="coupon-item {{item.status === 1 ? 'used' : ''}} {{item.status === 2 ? 'expired' : ''}}" wx:for="{{coupons}}" wx:key="id">
    <view class="coupon-left"><text class="coupon-value" wx:if="{{item.type === 'amount'}}">¥{{item.discount_value}}</text><text class="coupon-value" wx:else>{{item.discount_value}}折</text><text class="coupon-condition" wx:if="{{item.condition_price > 0}}">满¥{{item.condition_price}}可用</text></view>
    <view class="coupon-right"><text class="coupon-name">{{item.name}}</text><text class="coupon-expire">有效期至 {{item.expired_at || '--'}}</text><text class="coupon-status" wx:if="{{item.status === 1}}">已使用</text><text class="coupon-status" wx:elif="{{item.status === 2}}">已过期</text></view>
  </view>
</view>
