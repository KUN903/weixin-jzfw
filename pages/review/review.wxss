/* review */
.page-review { background: #f5f5f5; min-height: 100vh; padding: 20rpx; }
.star-row { display: flex; }
.star { font-size: 52rpx; color: #eee; margin-right: 12rpx; }
.star.active { color: #FFC300; }
.review-input { width: 100%; min-height: 200rpx; font-size: 28rpx; color: #333; padding: 12rpx 0; }
.submit-btn { margin-top: 40rpx; text-align: center; border-radius: 50rpx; padding: 26rpx; font-size: 30rpx; }
